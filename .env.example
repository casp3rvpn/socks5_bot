# Telegram Bot Token (get from @BotFather)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Optional: Allowed user IDs (comma-separated). Leave empty for public bot.
# ALLOWED_USERS=123456789,987654321

# Proxy update interval in minutes
UPDATE_INTERVAL=10

# Maximum number of proxies to keep
MAX_PROXIES=100

# Maximum concurrent proxy tests (higher = faster)
MAX_CONCURRENT_TESTS=100

# Cache file path
CACHE_FILE=proxies_cache.json
